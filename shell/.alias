# alias
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ls='ls -a --color=auto'

# neovim
alias nv="nvim"
alias vi="nvim"
alias vim="nvim"
alias view="nvim -R"

# python
alias python="python3"
alias py="python3"

# open applications
alias br="open /Applications/Brave\ Browser.app"
alias nt="open /Applications/Notion.app"
alias sl="open /Applications/Slack.app"
alias setting='open -a "System Preferences"'
alias ff='osascript -e '\''tell application "Finder" to activate'\'''


# microsoft office
alias pp="open /Applications/Microsoft\ PowerPoint.app/"
alias wd="open /Applications/Microsoft\ Word.app/"
alias excel="open /Applications/Microsoft\ Excel.app/"
alias te='osascript -e '\''tell application "Microsoft Teams" to activate'\'''


# neovim
alias v="nvim"
# Cursor, Command + Shift + P -> Shell Command: Install 'cursor' command in PATH
alias c="cursor ."

# github copilot for cli → abbr に移行済み（sug, exp）

# cpp関連
alias g="g++ -std=c++23 -O2"
alias a="./a.out"
# ga → abbr に移行済み

# python3関連
alias pp="python3 a.py|pbcopy"
alias p="python3"
# pa → abbr に移行済み
alias dp="python3 data.py|pbcopy"
alias vp="v a.py"
alias pc="cat a.py|pbcopy"
alias vc="v a.cpp"

# git関連 → abbr に移行済み（gs, gb, gco, gct, gd, gl）

# mac
alias copy='pbcopy <'
alias timg='timg -pk --grid=1'
alias tt='pbpaste|plamo-translate'
alias "da_yokoyama.pem"="~/.ssh/da_yokoyama.pem"



# 起動しているインスタンス一覧の取得
alias ec2_running='aws ec2 describe-instances --output=table --query "Reservations[].Instances[?State.Name=='"'"'running'"'"'][].{InstanceId: InstanceId, PrivateIp: join('"'"', '"'"', NetworkInterfaces[].PrivateIpAddress), GlobalIP: join('"'"', '"'"', NetworkInterfaces[].Association.PublicIp), Platform:Platform, State: State.Name, SecurityGroupId: join('"'"', '"'"', SecurityGroups[].GroupId) ,Name: Tags[?Key=='"'"'Name'"'"'].Value|[0]}"'
# 全インスタンス一覧の取得
alias ec2_all='aws ec2 describe-instances --output=table --query "Reservations[].Instances[].{InstanceId: InstanceId, PrivateIp: join('"'"', '"'"', NetworkInterfaces[].PrivateIpAddress), GlobalIP: join('"'"', '"'"', NetworkInterfaces[].Association.PublicIp), Platform:Platform, State: State.Name, SecurityGroupId: join('"'"', '"'"', SecurityGroups[].GroupId) ,Name: Tags[?Key=='"'"'Name'"'"'].Value|[0]}"'
