abbr "exp"="gh copilot explain"
abbr "ga"="g++ -std=c++23 -O2 a.cpp -o a.out && ./a.out"
abbr "gb"="git branch"
abbr "gco"="git checkout"
abbr "gct"="git commit"
abbr "gd"="git diff"
abbr "gl"="git log"
abbr "gs"="git status"
abbr "op"="open ."
abbr "opd"="open ~/Documents"
abbr "opdl"="open ~/Downloads"
abbr "pa"="python3 a.py"
abbr "sug"="gh copilot suggest"
abbr "szsh"="source ~/.zshrc"
abbr "tmuxrc"="v ~/.tmux.conf"
abbr "tree"="eza --icons --tree"
abbr "zshrc"="v ~/.zshrc"
