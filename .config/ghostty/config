# Theme
theme = Tomorrow Night Bright

# Window
background-opacity = 0.87

maximize = true
window-decoration = false
window-padding-x = 5
window-padding-y = 2

# Cursor
cursor-style = bar

# Scrollback
scrollback-limit = 10000000

# Font
font-family = "0xProto"
font-family = "Osaka-Mono"
font-size = 14
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
adjust-cell-height = 0
font-thicken = false
font-feature = -dlig
# Keybind (Cmd+Return → Neovim RunCurrentFile)
keybind = cmd+enter=text:\x1b:lua RunCurrentFile()\x0d
# Cmd+j → ToggleTerm / Cmd+b → Neotree toggle
keybind = cmd+j=text:\x1b:ToggleTerm\x0d
keybind = cmd+b=text:\x1b:Neotree toggle\x0d

# Shell (tmux auto-start)
command = /bin/zsh -l -c "exec ~/.config/ghostty/start_tmux.sh"
